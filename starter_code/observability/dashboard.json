{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Product Service Invocations and Errors",
        "region": "us-east-1",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          ["AWS/Lambda", "Invocations", "FunctionName", "shopfast-product-service-dev", { "stat": "Sum", "label": "Invocations" }],
          [".", "Errors", ".", ".", { "stat": "Sum", "label": "Errors" }]
        ],
        "period": 60
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 0,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Product Service Duration",
        "region": "us-east-1",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          ["AWS/Lambda", "Duration", "FunctionName", "shopfast-product-service-dev", { "stat": "p50", "label": "p50 Duration" }],
          [".", ".", ".", ".", { "stat": "p99", "label": "p99 Duration" }]
        ],
        "period": 60,
        "yAxis": {
          "left": {
            "label": "Milliseconds"
          }
        }
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 0,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Application EMF Metrics",
        "region": "us-east-1",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          ["ShopFast/Application", "ProductViews", "Service", "product-service", { "stat": "Sum" }],
          [".", "Errors", ".", ".", { "stat": "Sum" }],
          [".", "CacheHits", ".", ".", { "stat": "Sum" }],
          [".", "CacheMisses", ".", ".", { "stat": "Sum" }]
        ],
        "period": 60
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 6,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "Recent Product Service Errors",
        "region": "us-east-1",
        "query": "SOURCE '/aws/lambda/shopfast-product-service-dev' | fields @timestamp, level, message, request_id, path, product_id, error_type | filter level = \"ERROR\" | sort @timestamp desc | limit 20",
        "view": "table"
      }
    }
  ]
}
